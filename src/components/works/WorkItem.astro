---
import { Badge } from "../ui/badge";
import { Separator } from "../ui/separator";

import { BlOB_TRACKING_ClASS, CORNER_POSITIONS, PAGE_LINKS } from "@/consts";
import type { WorkObj } from "@/lib/fetchContents";
import { cn } from "@/lib/utils";

type Props = Pick<
  WorkObj,
  "documentId" | "title" | "description" | "tags" | "releaseDate"
>;

type Tag = NonNullable<WorkObj["tags"]>[number];

const worksHref = PAGE_LINKS.find((link) => link.title === "Works")
  ?.href as string;

const { documentId, title, description, tags, releaseDate } = Astro.props;

const { border, plus } = BlOB_TRACKING_ClASS;
---

<a href={`/${worksHref}/${documentId}`}>
  <div
    id="workItem"
    class="group relative z-0 flex cursor-pointer flex-col gap-1 py-2 hover:border-x sm:px-3"
  >
    {
      CORNER_POSITIONS.map(([transform, pos]) => (
        <span
          class={cn(plus, pos, transform, "opacity-0 group-hover:opacity-100")}
        >
          +
        </span>
      ))
    }
    <p class="text-2xl font-semibold">{title}</p>
    <p class="text-muted-foreground">{description}</p>
    <div class="flex items-center justify-between">
      <div class="flex gap-3">
        {
          (tags as Tag[])?.map((tag) => (
            <Badge variant="secondary" className="rounded-none p-0">
              {tag.name}
            </Badge>
          ))
        }
      </div>
      <p class="font-mono text-sm text-muted-foreground">
        {releaseDate}
      </p>
    </div>
  </div>
  <Separator className={cn(border, "border-border")} />
</a>

<style>
  #workItem:hover {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 3px,
      rgba(180, 180, 180, 0.2) 3px,
      rgba(180, 180, 180, 0.2) 4px
    );
  }
</style>
