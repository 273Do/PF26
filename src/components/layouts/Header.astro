---
import { Image } from "astro:assets";

import { ThemeToggle } from "../ThemeToggle";
import { MobilePageNavigation } from "./MobilePageNavigation";
import PageNavigation from "./PageNavigation.astro";

import { fetchWorks } from "@/lib/fetchContents";
import { cn } from "@/lib/utils";

const pathname = Astro.url.pathname
  .replace(import.meta.env.BASE_URL, "")
  .split("/")[0];

const isLP = pathname === "";

const { count: worksCount } = await fetchWorks();
---

<header
  class={cn(
    isLP ? "dark:sm:mix-blend-difference" : "bg-background",
    "fixed z-100 flex h-9 w-full items-center justify-between px-3 sm:px-6",
  )}
>
  <a href="/">
    <Image
      class="dark:invert"
      src={"/svg/logo.svg"}
      alt="273* Logo"
      width={45}
      height={45}
      priority
    />
  </a>
  <PageNavigation currentPath={pathname} worksCount={worksCount} />
  <MobilePageNavigation
    currentPath={pathname}
    worksCount={worksCount}
    client:load
  />
  <div class="hidden sm:flex">
    <ThemeToggle client:load />
  </div>
</header>
