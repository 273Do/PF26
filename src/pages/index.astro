---
import TextReveal from "@/components/animations/TextReveal.astro";
import Layouts from "@/components/layouts/Layouts.astro";
import { LogoCanvas } from "@/components/lp/LogoCanvas";

// user agent を判定するためルートページだけ SSR にする
export const prerender = false;
---

<Layouts>
  <div
    class="flex h-[calc(100dvh-36px)] w-full items-end justify-center overflow-hidden"
  >
    <div class="w-full">
      <LogoCanvas client:load />
      <TextReveal
        text="PORTFOLIO"
        class="translate-y-2 leading-none font-semibold md:translate-y-4 lg:translate-y-5.5"
      />
    </div>
  </div>
</Layouts>
