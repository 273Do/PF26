---
import TextReveal from "@/components/animations/TextReveal.astro";
import Layouts from "@/components/layouts/Layouts.astro";
import WorkList from "@/components/works/WorkList.astro";
---

<!doctype html>
<html lang="en">
  <Layouts>
    <div class="block w-full items-start justify-end sm:flex">
      <div class="block h-[3vh] sm:hidden"></div>
      <div class="left-6 flex w-3/5 sm:fixed sm:block sm:w-2/5 md:space-y-3">
        <TextReveal
          text="Works"
          class="leading-none font-semibold md:translate-y-4 lg:translate-y-6"
        />
        <!-- <WorksCount locale={locale} /> -->
      </div>
      <WorkList />
    </div>
  </Layouts>
</html>
